{
  "name": "singularity",
  "version": "1.3.7",
  "description": "Singularity IPTV Player",
  "main": "out/main/index.js",
  "author": "Singularity",
  "license": "MIT",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "build:web": "vite build --config vite.web.config.ts",
    "build:android": "npm run build:web && npx cap sync android",
    "build:apk": "npm run build:android && node scripts/build-apk.js",
    "dev:web": "vite --config vite.web.config.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@tanstack/react-virtual": "^3.10.7",
    "bonjour-service": "^1.3.0",
    "castv2-client": "^1.2.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "framer-motion": "^11.15.0",
    "hls.js": "^1.5.17",
    "mpegts.js": "^1.8.0",
    "node-ssdp": "^4.0.1",
    "pako": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^1.8.10",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.10.0",
    "@types/node-ssdp": "^4.0.5",
    "@types/pako": "^2.0.3",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "patch-package": "^8.0.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.0"
  }
}
